graph TB
    subgraph Encoder["Encoder (N=6 tầng)"]
        direction TB
        E_IN["Input Embedding
+ Positional Encoding"] --> E_ATTN["Multi-Head
Self-Attention"]
        E_ATTN --> E_NORM1["Add & Norm"]
        E_NORM1 --> E_FF["Feed Forward
Network"]
        E_FF --> E_NORM2["Add & Norm"]
        E_NORM2 --> E_OUT["Encoder Output"]
    end
    
    subgraph Decoder["Decoder (N=6 tầng)"]
        direction TB
        D_IN["Output Embedding
+ Positional Encoding"] --> D_MASK["Masked Multi-Head
Self-Attention"]
        D_MASK --> D_NORM1["Add & Norm"]
        D_NORM1 --> D_CROSS["Multi-Head
Cross-Attention"]
        D_CROSS --> D_NORM2["Add & Norm"]
        D_NORM2 --> D_FF["Feed Forward
Network"]
        D_FF --> D_NORM3["Add & Norm"]
    end
    
    E_OUT --> D_CROSS
    D_NORM3 --> LINEAR["Linear Layer"]
    LINEAR --> SOFTMAX["Softmax"]
    SOFTMAX --> OUTPUT["Output Tokens"]
    
    style Encoder fill:#e8eaf6
    style Decoder fill:#fff3e0